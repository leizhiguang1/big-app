NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- multi-brand routing ---
# Root domain that the app is hosted under. The middleware uses this to
# extract the subdomain (everything before this suffix) and resolve the
# brand. Local dev: "localhost". Production: "bigapp.online".
# Apex visitors (no subdomain) see the workspace picker; brand visitors
# (e.g. bigdental.bigapp.online) see the actual app.
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# --- wa-crm (WhatsApp inbox service) ---
# Base URL of the wa-crm backend. Browser connects here via Socket.IO from /inbox.
# Same Railway URL is used for dev and prod — no need to run wa-crm locally.
# Override to http://localhost:3001 only if you intentionally run a second
# wa-crm copy locally for debugging.
NEXT_PUBLIC_WA_CRM_URL=https://wa-big.up.railway.app
